# =============================================
# Bulkbeat TV – Production .env Template
# Copy this to .env on your VM and fill values
# =============================================

# --- Telegram (Main Signal Bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Telegram (Admin Panel Bot) ---
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Security (REQUIRED – run scripts/generate_hash.py) ---
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_TIMEOUT_MINUTES=60

# --- AI Intelligence Engine ---
SARVAM_API_KEY=

# --- Razorpay (Payment Gateway) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Subscription Plans (Format: Price:Days) ---
PLAN_99=99:2
PLAN_499=499:7
PLAN_999=999:28
PLAN_7999=7999:336

# --- Alert Policy (Optional Tuning) ---
ALERT_POLICY_MODE=ULTRA_STRICT_8PLUS
DAILY_ALERT_HARD_CAP=10
SYMBOL_COOLDOWN_MIN=90
NEUTRAL_BLOCK=1

# --- Email Alerts (Optional) ---
ALERT_EMAILS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
